<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout android:id="@+id/card_key"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// GEMINI API KEY" android:textColor="@color/text_hint"
                android:textSize="11sp" android:fontFamily="monospace" android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/tv_key_status" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:fontFamily="monospace" android:layout_marginBottom="10dp"/>
            <EditText android:id="@+id/et_api_key" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:background="@drawable/bg_input"
                android:textColor="@color/accent_red" android:textColorHint="@color/text_hint"
                android:hint="AIzaSy..." android:textSize="12sp" android:fontFamily="monospace"
                android:inputType="textPassword" android:padding="12dp" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btn_save_key" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="[ ЗБЕРЕГТИ ]"
                android:background="@drawable/bg_btn_outline"
                android:textColor="@color/accent_red" android:textSize="13sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/card_tap"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// РЕЖИМ КНОПКИ" android:textColor="@color/text_hint"
                android:textSize="11sp" android:fontFamily="monospace" android:layout_marginBottom="10dp"/>
            <RadioGroup android:id="@+id/rg_tap" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical">
                <RadioButton android:id="@+id/rb_single" android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ОДНЕ ТОРКАННЯ → аналіз"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:fontFamily="monospace" android:buttonTint="@color/accent_red"
                    android:layout_marginBottom="8dp"/>
                <RadioButton android:id="@+id/rb_double" android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ПОДВІЙНЕ ТОРКАННЯ → аналіз"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:fontFamily="monospace" android:buttonTint="@color/accent_red"/>
            </RadioGroup>
        </LinearLayout>

        <LinearLayout android:id="@+id/card_autotap"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// АВТО ВІДПОВІДІ" android:textColor="@color/text_hint"
                android:textSize="11sp" android:fontFamily="monospace" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Показувати відповідь автоматично"
                    android:textColor="@color/text_primary" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <Switch android:id="@+id/sw_auto_tap" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent_red" android:trackTint="#44CC0000"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Затримка відповіді:"
                android:textColor="@color/text_secondary" android:textSize="12sp"
                android:fontFamily="monospace" android:layout_marginBottom="6dp"/>
            <SeekBar android:id="@+id/sb_delay" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:max="10" android:progress="4"
                android:progressTint="@color/accent_red" android:thumbTint="@color/accent_red"/>
            <TextView android:id="@+id/tv_delay_val"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2.0с" android:textColor="@color/accent_red"
                android:textSize="12sp" android:fontFamily="monospace" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/card_plan_settings"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// ПІДПИСКА" android:textColor="@color/text_hint"
                android:textSize="11sp" android:fontFamily="monospace" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tv_plan_info"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:fontFamily="monospace" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btn_upgrade" android:layout_width="match_parent"
                android:layout_height="46dp" android:text="◆ UPGRADE TO PRO — 30 грн/міс"
                android:background="@drawable/bg_btn_primary"
                android:textColor="#FFFFFF" android:textSize="13sp"
                android:textStyle="bold" android:fontFamily="monospace"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/card_account"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// АКАУНТ" android:textColor="@color/text_hint"
                android:textSize="11sp" android:fontFamily="monospace" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tv_name" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                android:textSize="13sp" android:fontFamily="monospace" android:layout_marginBottom="12dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Скинути ім'я"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:fontFamily="monospace"/>
                <Switch android:id="@+id/sw_reset" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent_red" android:trackTint="#44CC0000"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
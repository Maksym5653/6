<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout android:id="@+id/card_dev_header"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card_red" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚡ DEVELOPER MODE — ROOT ACCESS"
                android:textColor="@color/accent_red" android:textSize="14sp"
                android:textStyle="bold" android:fontFamily="monospace" android:layout_marginBottom="6dp"/>
            <TextView android:id="@+id/tv_dev_stats"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:textSize="12sp"
                android:fontFamily="monospace" android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/card_users_log"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="// ЛОГ КОРИСТУВАЧІВ"
                    android:textColor="@color/text_hint" android:textSize="11sp" android:fontFamily="monospace"/>
                <Button android:id="@+id/btn_clear_users"
                    android:layout_width="wrap_content" android:layout_height="32dp"
                    android:text="ОЧИСТИТИ" android:background="@drawable/bg_btn_outline"
                    android:textColor="@color/accent_red" android:textSize="10sp"
                    android:fontFamily="monospace" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_users"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#BB4444" android:textSize="11sp"
                android:fontFamily="monospace" android:lineSpacingMultiplier="1.6"
                android:padding="10dp" android:background="#08330000"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/card_errors_log"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="// ЛОГ ПОМИЛОК"
                    android:textColor="@color/text_hint" android:textSize="11sp" android:fontFamily="monospace"/>
                <Button android:id="@+id/btn_clear_errors"
                    android:layout_width="wrap_content" android:layout_height="32dp"
                    android:text="ОЧИСТИТИ" android:background="@drawable/bg_btn_outline"
                    android:textColor="@color/accent_red" android:textSize="10sp"
                    android:fontFamily="monospace" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            </LinearLayout>
            <TextView android:id="@+id/tv_errors"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColor="#AA3333" android:textSize="11sp"
                android:fontFamily="monospace" android:lineSpacingMultiplier="1.6"
                android:padding="10dp" android:background="#08330000"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/card_dev_actions"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="14dp"
            android:orientation="vertical" android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="// PRO УПРАВЛІННЯ" android:textColor="@color/text_hint"
                android:textSize="11sp" android:fontFamily="monospace" android:layout_marginBottom="10dp"/>
            <EditText android:id="@+id/et_pro_user"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_input" android:textColor="@color/accent_red"
                android:textColorHint="@color/text_hint" android:hint="ім'я користувача..."
                android:textSize="13sp" android:fontFamily="monospace" android:padding="12dp"
                android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btn_grant_pro"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:text="[ ВИДАТИ PRO ]" android:background="@drawable/bg_btn_primary"
                android:textColor="#FFFFFF" android:textSize="13sp"
                android:textStyle="bold" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tv_granted"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/accent_red" android:textSize="12sp"
                android:fontFamily="monospace" android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
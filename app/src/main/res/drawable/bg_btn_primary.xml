<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#880000" android:endColor="#550000" android:angle="135"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#CC1111" android:endColor="#AA0000" android:angle="135"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</selector>